# Environment variables for SRE Agent Swarm
# Copy this file to .env and set values for your environment

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=console   # 'json' for production, 'console' for dev

# ---------------------------------------------------------------------------
# NATS (message bus)
# ---------------------------------------------------------------------------
NATS_URL=nats://localhost:4222

# ---------------------------------------------------------------------------
# PostgreSQL — Agent incident store (port 5432)
# ---------------------------------------------------------------------------
AGENTS_DB_HOST=localhost
AGENTS_DB_PORT=5432
AGENTS_DB_NAME=agents
AGENTS_DB_USER=postgres
AGENTS_DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# PostgreSQL — Orders (port 5433)
# ---------------------------------------------------------------------------
ORDERS_DB_HOST=localhost
ORDERS_DB_PORT=5433
ORDERS_DB_NAME=orders
ORDERS_DB_USER=postgres
ORDERS_DB_PASSWORD=postgres

# Used by Go order-service directly
DATABASE_URL=postgres://postgres:postgres@localhost:5433/orders?sslmode=disable

# ---------------------------------------------------------------------------
# PostgreSQL — Payments (port 5434)
# ---------------------------------------------------------------------------
PAYMENTS_DB_HOST=localhost
PAYMENTS_DB_PORT=5434
PAYMENTS_DB_NAME=payments
PAYMENTS_DB_USER=postgres
PAYMENTS_DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Auth Service
# ---------------------------------------------------------------------------
# CHANGE THIS IN PRODUCTION — use a random 32+ char secret
JWT_SECRET=dev-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------------------------------------------------------------------------
# Observability (Phase 2+)
# ---------------------------------------------------------------------------
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
TEMPO_URL=http://localhost:3200